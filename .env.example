# Database
DATABASE_URL=postgresql://apex:apex@localhost:5432/apex

# Redis
REDIS_URL=redis://localhost:6379

# API Auth
API_KEY=your-secret-api-key-here

# Kalshi
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# Polymarket
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_API_KEY=

# API Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Dashboard
VITE_API_URL=http://localhost:3001/api/v1
VITE_API_KEY=your-secret-api-key-here

# Claude API (LLM modules)
ANTHROPIC_API_KEY=
LLM_DAILY_BUDGET=10.00

# FRED Economic Data (optional — higher rate limits with key)
FRED_API_KEY=

# Congress.gov API (free — api.congress.gov)
CONGRESS_API_KEY=

# The Odds API — sports odds, free tier 500 req/month (the-odds-api.com)
ODDS_API_KEY=

# Finnhub — earnings, analyst estimates, SEC filings, free tier 60 calls/min (finnhub.io)
FINNHUB_API_KEY=

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# TRADEX — Automated Execution Engine
TRADEX_ENABLED=false                           # Master kill switch — must explicitly enable
TRADEX_FAST_EXEC_ENABLED=false                 # Separate toggle for auto-execution
KALSHI_USE_DEMO=true                           # Start in demo/sandbox mode
POLYMARKET_PRIVATE_KEY=                        # Dedicated ETH wallet private key
POLYGON_RPC_URL=https://polygon-rpc.com        # Polygon RPC endpoint
